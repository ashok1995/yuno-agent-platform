# Ollama (local LLM runtime)
OLLAMA_URL=http://127.0.0.1:11434/api/generate
OLLAMA_MODEL=qwen3.5:9b
ROUTING_MODEL=qwen3.5:9b
OLLAMA_THINK=false

# Telegram external channel — create via @BotFather
TELEGRAM_BOT_TOKEN=
TELEGRAM_REPLY_TIMEOUT_SEC=120

# Logging
LOG_LEVEL=INFO
LOG_FILE_PATH=

# API bind (optional)
API_HOST=127.0.0.1
API_PORT=8000

# SQLite path (optional; default: backend/platform.db)
DATABASE_PATH=
